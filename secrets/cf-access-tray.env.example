# Cloudflare Access service-token credentials for the Windows BrokerTray.
#
# Copy this file to cf-access-tray.env (drop the .example suffix) on the NUC at:
#   C:\dashboard\secrets\cf-access-tray.env
# and replace the placeholders with the real service-token values from
# the Cloudflare Zero Trust dashboard (Access -> Service Auth -> create token).
# The tray reads it on startup; restart the tray (deploy/nuc/restart-tray.ps1)
# after changing the file.
#
# DO NOT COMMIT the real cf-access-tray.env - secrets/ is gitignored.

CF_ACCESS_CLIENT_ID=REPLACE_WITH_TOKEN.access
CF_ACCESS_CLIENT_SECRET=REPLACE_WITH_LONG_HEX_SECRET
