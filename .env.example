APP_ENV=dev
APP_SECRET_KEY=change-me-32-bytes-base64
APP_CORS_ORIGINS=["http://localhost:5173"]

# Postgres runs NATIVELY on Windows on the NUC15PRO — never in Docker.
# Use the NUC's WireGuard IP 10.10.0.2:5432 for BOTH dev and prod:
#   - Dev (Docker on WSL): container egress NATs to the NUC's WG-interface IP (10.10.0.2),
#     so PG sees the connection source as 10.10.0.2 too. pg_hba.conf must allow
#     `host all trader 10.10.0.0/24 scram-sha-256` (covers NUC self-NAT + VPS peers).
#   - Prod (VPS on WireGuard): reaches the same PG at 10.10.0.2:5432.
# `host.docker.internal` does NOT work with docker-ce inside WSL (only Docker Desktop
# tunnels it to the Windows host). See memory wsl_docker_pg_self_nat.md.
#
# New rebuild uses DB name "dashboard" to coexist with the legacy "trading" DB on the same server.
DATABASE_URL=postgresql+asyncpg://trader:change-me@10.10.0.2:5432/dashboard
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Redis — runs in Docker (compose locally; Phase 1 will run it on VPS).
# NOTE: keep the password URL-safe (no special characters that need escaping).
REDIS_PASSWORD=change-me-url-safe
REDIS_URL=redis://:change-me-url-safe@redis:6379/0
