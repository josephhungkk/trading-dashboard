# Phase 8a/8b empirical hard-gate artifacts -- contain raw broker responses
# (account hashes, broker order IDs, internal status payloads). Never commit.
scripts/empirical/artifacts/*
!scripts/empirical/artifacts/.gitkeep

# Phase 9 empirical history JSONL artifacts -- per-script timestamped runs.
tmp/empirical/
